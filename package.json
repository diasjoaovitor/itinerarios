{
  "name": "next-boilerplate",
  "version": "1.0.0",
  "description": "Next.js Boilerplate",
  "repository": "https://github.com/diasjoaovitor/next-boilerplate.git",
  "author": "João Vitor <jvitordiass@outlook.com.br>",
  "license": "MIT",
  "scripts": {
    "dev": "./init-dev.sh",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f src/infra/compose.yml up -d",
    "services:stop": "docker compose -f src/infra/compose.yml stop",
    "services:down": "docker compose -f src/infra/compose.yml down",
    "lint": "next lint",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "prepare": "husky",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:ci": "jest --runInBand",
    "generate": "plop --plopfile generators/plopfile.js"
  },
  "dependencies": {
    "@tanstack/query-core": "^5.51.9",
    "@tanstack/react-query": "^5.51.1",
    "bluebird": "^3.7.2",
    "dayjs": "^1.11.11",
    "mysql2": "^3.10.2",
    "next": "^14.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.2.1",
    "styled-components": "^6.1.11",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.51.1",
    "@tanstack/react-query-devtools": "^5.51.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/bluebird": "^3.5.42",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "eslint": "^8",
    "eslint-config-next": "^14.2.2",
    "eslint-config-prettier": "^9.1.0",
    "git-commit-msg-linter": "^5.0.7",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.2",
    "plop": "^4.0.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
