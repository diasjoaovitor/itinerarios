{
  "name": "next-boilerplate",
  "version": "1.0.0",
  "description": "Next.js Boilerplate",
  "repository": "https://github.com/diasjoaovitor/next-boilerplate.git",
  "author": "João Vitor <jvitordiass@outlook.com.br>",
  "license": "MIT",
  "scripts": {
    "dev": "./init-dev.sh",
    "build": "next build",
    "start": "next start",
    "services:up": "docker compose -f src/infra/compose.yml up -d",
    "services:stop": "docker compose -f src/infra/compose.yml stop",
    "services:down": "docker compose -f src/infra/compose.yml down",
    "lint": "next lint",
    "lint:check": "prettier --check .",
    "lint:fix": "prettier --write .",
    "prepare": "husky",
    "test": "jest --runInBand",
    "test:interface": "jest interface",
    "test:integration": "jest --runInBand integration",
    "test:watch:interface": "jest --watchAll interface",
    "test:watch:integration": "jest --runInBand --watchAll integration",
    "generate": "plop --plopfile generators/plopfile.js"
  },
  "dependencies": {
    "bluebird": "^3.7.2",
    "dayjs": "^1.11.11",
    "dotenv": "^16.4.5",
    "mysql2": "^3.9.7",
    "next": "^14.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xior": "^0.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/bluebird": "^3.5.42",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "cross-fetch": "^4.0.0",
    "eslint": "^8",
    "eslint-config-next": "^14.2.2",
    "eslint-config-prettier": "^9.1.0",
    "git-commit-msg-linter": "^5.0.7",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.2",
    "plop": "^4.0.1",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
